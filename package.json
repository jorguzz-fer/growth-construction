{
  "name": "growth-tools-construction",
  "version": "0.1.0",
  "description": "FP&A SaaS para incorporadoras imobiliárias — Growth Tools / TFG",
  "author": "Tools for Growth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts",
    "build:migrate": "esbuild src/lib/db/migrate.ts --bundle --platform=node --target=node22 --format=esm --outfile=.migrate/migrate.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "build:seed": "esbuild src/lib/db/seed.ts --bundle --platform=node --target=node22 --format=esm --outfile=.migrate/seed.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\""
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "lucide-react": "^0.469.0",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.25",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
