# Copie para .env.local (dev) ou configure como secrets no Coolify (prod).
# Ver docs/STACK.md §5.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# gere com: openssl rand -base64 32
AUTH_SECRET=
# necessário em produção atrás de proxy (Traefik/Coolify)
AUTH_TRUST_HOST=true

# Postgres (interno do Coolify em produção)
DATABASE_URL=postgresql://user:pass@localhost:5432/growthtools

# Redis (filas BullMQ / cache — Fase 4+)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatível) — repositório de documentos (Fase 3)
R2_ENDPOINT=https://__account_id__.r2.cloudflarestorage.com
R2_BUCKET=documentos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
# opcional: domínio público/custom do bucket
R2_PUBLIC_URL=

# Open Finance (Pluggy) — Fase 4
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
