# Copie para .env.local (dev) ou configure como secrets no Coolify (prod).
# Ver docs/STACK.md §5.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# gere com: openssl rand -base64 32
AUTH_SECRET=
# necessário em produção atrás de proxy (Traefik/Coolify)
AUTH_TRUST_HOST=true
# MFA (verificação em duas etapas): "true" = obrigatório; ausente/qualquer
# outro valor = standby (fase de testes, login só com e-mail+senha).
MFA_ENFORCED=
# Super-admins da plataforma (podem criar/gerenciar contas/tenants em
# /superadmin). Lista de e-mails separada por vírgula. Se ausente, usa o
# bootstrap com os operadores conhecidos (fer.jorge@ / thiago.liberman@).
SUPERADMIN_EMAILS=

# Postgres (interno do Coolify em produção)
DATABASE_URL=postgresql://user:pass@localhost:5432/growthtools

# Redis (filas BullMQ / cache — Fase 4+)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (S3-compatível) — repositório de documentos (Fase 3)
R2_ENDPOINT=https://__account_id__.r2.cloudflarestorage.com
R2_BUCKET=documentos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
# opcional: domínio público/custom do bucket
R2_PUBLIC_URL=

# Open Finance (Pluggy) — Fase 4
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# IA — leitura de documentos (NF/boleto) para preencher despesas (Anthropic/Claude).
# Sem esta chave, o upload/vínculo do documento funciona, mas a leitura
# automática por IA fica desabilitada. Ver src/lib/ai/despesa-extract.ts.
ANTHROPIC_API_KEY=
